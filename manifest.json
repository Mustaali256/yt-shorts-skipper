{
  "manifest_version": 3,
  "name": "YouTube Shorts Sponsor Skipper",
  "version": "1.0",
  "description": "Skips YouTube Shorts when Sponsored text appears.",
  "permissions": [],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
"icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}