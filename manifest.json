{
  "manifest_version": 3,
  "name": "YouTube Shorts Sponsor Skipper",
  "version": "1.0",
  "description": "Skips YouTube Shorts when Sponsored text appears.",
  "permissions": [],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}